{
  "name": "pi-research",
  "version": "0.1.0",
  "description": "Multi-agent research orchestration extension for pi. Coordinator + parallel/sequential researchers with web search, scraping, security databases, and Stack Exchange integration.",
  "type": "module",
  "private": false,
  "main": "index.ts",
  "files": [
    "index.ts",
    "src/",
    "prompts/",
    "config/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Lincoln504/pi-research.git"
  },
  "homepage": "https://github.com/Lincoln504/pi-research#readme",
  "bugs": {
    "url": "https://github.com/Lincoln504/pi-research/issues"
  },
  "keywords": [
    "pi",
    "research",
    "agent",
    "orchestration",
    "web-search",
    "scraping",
    "security",
    "stack-exchange"
  ],
  "author": "Lincoln504",
  "license": "MIT",
  "scripts": {
    "lint": "npx eslint src/",
    "lint:fix": "npx eslint src/ --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config vitest.config.unit.ts",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:watch": "vitest --config vitest.config.unit.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@kreuzberg/html-to-markdown-node": "^2.28.2",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*",
    "dockerode": "^4.0.10",
    "js-yaml": "^4.1.1",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dockerode": "^4.0.1",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.0",
    "testcontainers": "^11.13.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
