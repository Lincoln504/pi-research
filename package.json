{
  "name": "@lincoln504/pi-research",
  "version": "0.1.14",
  "description": "A set of web research tools (search, scrape, and others) and research agent system that uses them safely and efficiently.",
  "type": "module",
  "private": false,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src/",
    "docs/",
    "scripts/",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lincoln504/pi-research.git"
  },
  "homepage": "https://github.com/Lincoln504/pi-research#readme",
  "bugs": {
    "url": "https://github.com/Lincoln504/pi-research/issues"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "research",
    "agent",
    "web-search",
    "scraping",
    "stealth-browser",
    "camoufox",
    "security",
    "stack-exchange"
  ],
  "author": "Lincolndeen",
  "contributors": [
    "MuratAitov"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "lint": "npx eslint --config config/tooling/eslint.config.js src/",
    "lint:fix": "npx eslint --config config/tooling/eslint.config.js src/ --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config config/tooling/vitest.config.unit.ts",
    "test:unit": "vitest run --config config/tooling/vitest.config.unit.ts",
    "test:integration": "vitest run --config config/tooling/vitest.config.integration.ts",
    "test:watch": "vitest --config config/tooling/vitest.config.unit.ts",
    "test:coverage": "vitest run --config config/tooling/vitest.config.unit.ts --coverage",
    "postinstall": "node scripts/setup.cjs",
    "preuninstall": "node scripts/cleanup.cjs",
    "setup": "node scripts/setup.cjs",
    "install:browsers": "node scripts/setup.cjs",
    "install:system-deps": "node scripts/setup.cjs --system-deps"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "@kreuzberg/html-to-markdown-node": "^2.30.0",
    "@mariozechner/pi-tui": "^0.73.0",
    "camoufox-js": "^0.10.2",
    "node-html-markdown": "^2.0.0",
    "pdf-oxide-wasm": "^0.3.37",
    "playwright-core": "^1.59.1",
    "poolifier": "^5.3.2",
    "typebox": "^1.0.0"
  },
  "optionalDependencies": {
    "@kreuzberg/html-to-markdown-node-darwin-arm64": "^2.30.0",
    "@kreuzberg/html-to-markdown-node-darwin-x64": "^2.30.0",
    "@kreuzberg/html-to-markdown-node-linux-arm64-gnu": "^2.30.0",
    "@kreuzberg/html-to-markdown-node-linux-arm64-musl": "^2.30.0",
    "@kreuzberg/html-to-markdown-node-linux-x64-gnu": "^2.30.0",
    "@kreuzberg/html-to-markdown-node-linux-x64-musl": "^2.30.0",
    "@kreuzberg/html-to-markdown-node-win32-x64-msvc": "^2.30.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "overrides": {
    "lodash.isequal": "npm:fast-deep-equal@^3.1.3",
    "ip-address": "^10.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-ai": "^0.72.1",
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
