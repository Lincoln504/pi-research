# pi-research Configuration

# Per-researcher timeout in milliseconds (default: 240000)
# PI_RESEARCH_RESEARCHER_TIMEOUT_MS=240000

# SearXNG health check timeout in milliseconds (default: 15000)
# PI_RESEARCH_HEALTH_CHECK_TIMEOUT_MS=15000

# Proxy URL for SearXNG (optional)
# Examples:
# PROXY_URL=socks5://127.0.0.1:9050
# PROXY_URL=http://proxy.example.com:8080
# PROXY_URL=http://user:pass@proxy.example.com:8080

# Stack Exchange API Key (optional, for higher rate limits)
# STACKEXCHANGE_API_KEY=your_api_key_here
