# pi-research Configuration
# Copy this file to .env and edit values as needed

# ============================================
# PROXY CONFIGURATION (Optional)
# ============================================

# Proxy URL for SearXNG searches (optional)
# Supports SOCKS5 (Tor) or HTTP/HTTPS proxies
# Example: socks5://127.0.0.1:9050 (for Tor)
# Example: http://proxy.example.com:8080 (for HTTP proxy)
# Example: http://user:pass@proxy.example.com:8080 (for authenticated proxy)
# Default: undefined (no proxy - searches use direct connection)
PROXY_URL=

# ============================================
# RESEARCH CONFIGURATION
# ============================================

# Maximum research iterations
# Default: 3
# PI_RESEARCH_MAX_ITERATIONS=3

# Per-researcher timeout in milliseconds
# Default: 240000 (4 minutes)
PI_RESEARCH_RESEARCHER_TIMEOUT_MS=240000

# Flash indicator timeout in milliseconds
# Default: 1000
# PI_RESEARCH_FLASH_TIMEOUT_MS=1000

# ============================================
# USAGE
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Edit PROXY_URL if you want to use a proxy
# 3. Source file before running pi: source .env
#    OR add to your ~/.bashrc: source ~/Documents/pi-research/.env
# 4. Run pi: pi
