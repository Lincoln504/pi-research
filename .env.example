# pi-research Configuration
# Copy this file to .env and edit values as needed

# ============================================
# TOR PROXY CONFIGURATION
# ============================================

# Enable Tor proxy for SearXNG searches
# Default: false (Tor is disabled by default)
# Set to true to route all searches through Tor
PI_RESEARCH_ENABLE_TOR=false

# Tor SOCKS5 proxy port
# Default: 9050 (standard Tor port)
# Use 9150 for Tor Browser default
PI_RESEARCH_TOR_SOCKS_PORT=9050

# Tor control port
# Default: 9051
PI_RESEARCH_TOR_CONTROL_PORT=9051

# Auto-start Tor if not running
# Default: false (Tor must be started manually)
# Set to true to let pi-research start Tor automatically
PI_RESEARCH_TOR_AUTO_START=false

# ============================================
# RESEARCH CONFIGURATION
# ============================================

# Maximum research iterations
# Default: 3
PI_RESEARCH_MAX_ITERATIONS=3

# Per-researcher timeout in milliseconds
# Default: 60000 (60 seconds)
PI_RESEARCH_RESEARCHER_TIMEOUT_MS=60000

# Flash indicator timeout in milliseconds
# Default: 1000
PI_RESEARCH_FLASH_TIMEOUT_MS=1000

# ============================================
# USAGE
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Edit values as needed
# 3. Source the file before running pi: source .env
#    OR add to your ~/.bashrc: source ~/Documents/pi-research/.env
# 4. Run pi: pi
