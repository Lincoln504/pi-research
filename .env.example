# pi-research Configuration
#
# pi-research reads process.env. Use your shell, pi launcher, direnv, or another
# environment loader; the extension does not load this file by itself.

# External SearXNG URL (optional)
# When set, Docker container management is skipped entirely and this URL is used directly.
# Example: SEARXNG_URL=http://localhost:8080
# SEARXNG_URL=

# Per-researcher timeout in milliseconds (default: 240000)
# Valid range: 30000 (30s) to 600000 (10m)
# PI_RESEARCH_RESEARCHER_TIMEOUT_MS=240000

# Maximum researchers running simultaneously (default: 3, valid range: 1 to 10)
# PI_RESEARCH_MAX_CONCURRENT_RESEARCHERS=3

# Search language for filtering results (default: en-US)
# BCP 47 language tag (e.g., en-US, en-GB, es-ES, fr-FR)
# PI_RESEARCH_SEARCH_LANGUAGE=en-US

# Delay before TUI clears after research ends in milliseconds (default: 15000)
# PI_RESEARCH_CONSOLE_RESTORE_DELAY_MS=15000

# Number of parallel browser workers for search and scraping (default: 4)
# Valid range: 1 to 16. Higher values use more CPU and RAM.
# PI_RESEARCH_WORKER_THREADS=4

# SearXNG health timeout in milliseconds (optional)
# If unset, the network health check uses 15000 and container startup uses 120000.
# If set, this value overrides both.
# PI_RESEARCH_HEALTH_CHECK_TIMEOUT_MS=15000

# Global TUI refresh debounce in milliseconds (default: 10)
# PI_RESEARCH_TUI_REFRESH_DEBOUNCE_MS=10

# Verbose diagnostics (default: disabled)
# Writes JSONL logs to your OS temp directory as pi-research-debug-{hash}.log
# PI_RESEARCH_VERBOSE=1

# Proxy URL for SearXNG (optional)
# Used for routing search requests through a proxy (e.g., for rate limit avoidance)
# Host loopback addresses (localhost/127.0.0.1) are rewritten for Docker as host.docker.internal
# Examples:
# PROXY_URL=socks5://127.0.0.1:9050
# PROXY_URL=http://proxy.example.com:8080
# PROXY_URL=http://user:pass@proxy.example.com:8080
# PROXY_URL=

# Brave Search API key (optional)
# When set, enables the braveapi engine alongside the free scraping engines.
# The braveapi engine uses Brave's official REST API and is not subject to bot detection.
# Brave's API is pay-as-you-go ($0.005/query) — no free tier as of 2026.
# Obtain a key at: https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=your_api_key_here

# SearXNG Docker image tag (default: latest)
# Pin to a specific release for reproducibility (e.g., 2024.12.23)
# SEARXNG_IMAGE_TAG=latest

# Docker connection overrides (default: platform-specific)
# Linux/macOS default to the standard Unix socket.
# Windows defaults to Docker named pipes such as //./pipe/docker_engine.
# Set these only if you use a custom Docker daemon setup.
# DOCKER_HOST=unix:///var/run/docker.sock
# DOCKER_HOST=npipe:////./pipe/docker_engine
# DOCKER_HOST=tcp://127.0.0.1:2375
# DOCKER_SOCKET=/var/run/docker.sock
# DOCKER_SOCKET=//./pipe/docker_engine

# Stack Exchange API Key (optional, for higher rate limits)
# Obtain from: https://stackapps.com/apps/oauth
# STACKEXCHANGE_API_KEY=your_api_key_here
